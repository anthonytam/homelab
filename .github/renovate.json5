{
  enabled: true,
  semanticCommits: 'enabled',
  dependencyDashboard: true,
  dependencyDashboardTitle: 'Renovate Dashboard',
  suppressNotifications: [
    'prIgnoreNotification',
  ],
  rebaseWhen: 'conflicted',
  includePaths: [
    'kubernetes/cluster/**',
  ],
  'helm-values': {
    managerFilePatterns: [
      '/kubernetes/cluster/.+/helm-release\\.ya?ml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/kubernetes/cluster/.+\\.ya?ml$/',
    ],
    ignorePaths: [
      'kubernetes/cluster/flux-bootstrap/',
    ],
  },
  flux: {
    managerFilePatterns: [
      '/kubernetes/cluster/.+\\.ya?ml$/',
    ],
  },
  packageRules: [
    {
      matchDatasources: [
        'helm',
      ],
      separateMinorPatch: true,
      ignoreDeprecated: true,
    },
    {
      matchDatasources: [
        'docker',
      ],
      enabled: true,
      commitMessageTopic: 'container image {{depName}}',
      commitMessageExtra: 'to {{#if isSingleVersion}}v{{{newVersion}}}{{else}}{{{newValue}}}{{/if}}',
      matchUpdateTypes: [
        'major',
        'minor',
        'patch',
      ],
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'major',
      ],
      labels: [
        'renovate/image',
        'dep/major',
      ],
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'minor',
      ],
      labels: [
        'renovate/image',
        'dep/minor',
      ],
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'patch',
      ],
      labels: [
        'renovate/image',
        'dep/patch',
      ],
    },
    {
      matchDatasources: [
        'helm',
      ],
      matchUpdateTypes: [
        'major',
      ],
      labels: [
        'renovate/helm',
        'dep/major',
      ],
    },
    {
      matchDatasources: [
        'helm',
      ],
      matchUpdateTypes: [
        'minor',
      ],
      labels: [
        'renovate/helm',
        'dep/minor',
      ],
    },
    {
      matchDatasources: [
        'helm',
      ],
      matchUpdateTypes: [
        'patch',
      ],
      labels: [
        'renovate/helm',
        'dep/patch',
      ],
    },
    {
      matchUpdateTypes: ["patch"],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days"
    },
    {
      matchUpdateTypes: ["minor"],
      matchPackageNames: [
        "*",
        !"postgres",
        !"pgvector/pgvector",
        !"ghcr.io/immich-app/immich-machine-learning",
        !"ghcr.io/immich-app/immich-server",
        !"ghcr.io/sergelogvinov/charts/proxmox-csi-plugin",
        !"ghcr.io/toeverything/affine"
      ],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "7 days"
    },
    {
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      groupName: 'all non-major dependencies',
      groupSlug: 'all-minor-patch',
      matchPackageNames: [
        '*',
        '!homeassistant/home-assistant',
        '!fluxcd/flux2',
      ],
    },
  ],
}
